# ============================================================
# .env.example - Modelo de variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores conforme
# o seu ambiente de desenvolvimento ou produção.
# ============================================================

# Nome exibido na documentação da API
APP_NAME=API Gerenciamento de Tarefas

# Modo de depuração (True/False)
DEBUG=False

# URL de conexão com o banco de dados
# SQLite local:
DATABASE_URL=sqlite:///tasks.db
# PostgreSQL (exemplo para produção):
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/tarefas_db

# Endereço de escuta do servidor
HOST=0.0.0.0

# Porta do servidor
PORT=8000
